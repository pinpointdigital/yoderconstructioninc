{
  "build": {
    "commands": [
      "rm -rf .next out node_modules/.cache",
      "npm install", 
      "npm run build",
      "cd out",
      "find . -name '.*' -not -name '.well-known' -delete",
      "echo 'Build completed - forcing full sync'"
    ],
    "output_directory": "."
  },
  "deploy": {
    "source_path": ".",
    "target_path": "yoderconstructioninc.com/public_html/",
    "sync_method": "rsync",
    "rsync_options": "--delete-before --force --whole-file",
    "pre_deploy_commands": [
      "echo 'Starting complete file replacement deployment'"
    ],
    "exclude": [
      ".DS_Store",
      "*.log", 
      "node_modules",
      ".well-known"
    ]
  },
  "environment": {
    "NODE_VERSION": "18",
    "FORCE_FRESH_BUILD": "true"
  }
}