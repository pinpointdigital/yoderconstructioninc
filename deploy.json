{
  "build": {
    "commands": [
      "npm install",
      "npm run build"
    ],
    "output_directory": "out"
  },
  "deploy": {
    "source_path": "out/*",
    "target_path": "public_html/",
    "sync_method": "mirror",
    "exclude": [
      ".DS_Store",
      "*.log",
      "node_modules",
      ".gitignore",
      "README.md"
    ]
  },
  "environment": {
    "NODE_VERSION": "18",
    "BUILD_COMMAND": "npm run build"
  }
}